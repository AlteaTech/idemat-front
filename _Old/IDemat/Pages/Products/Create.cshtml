    <script>
        function Civilite(monTexte) {
            var blnSelect = (monTexte == document.getElementById('civiliteValeur').value);
            var inputs = document.getElementsByTagName("input");
            for (var i = 0; i < inputs.length; i++) {
                if (inputs[i].id.indexOf('civ_') == 0) {
                    //alert(inputs[i].id);
                    //document.getElementById(inputs[i].id).style.background = '#EEEEEE';
                    //document.getElementById(inputs[i].id).style.color = '#000000';
                    document.getElementById(inputs[i].id).className = 'idematnoirsurfondblanc';
                }
            }
            if (!blnSelect) {
                //document.getElementById('civ_' + monTexte).style.background = '#1560BD';
                //document.getElementById('civ_' + monTexte).style.color = '#FFFFFF';
                document.getElementById('civ_' + monTexte).className = 'idematblancsurfondnoir';
                document.getElementById('civiliteValeur').value = monTexte;
            }
            else {
                document.getElementById('civiliteValeur').value = '';
            }
        }

        function findBootstrapEnvironment() {
            let envs = ['xs', 'sm', 'md', 'lg', 'xl'];

            let el = document.createElement('div');
            document.body.appendChild(el);

            let curEnv = envs.shift();

            for (let env of envs.reverse()) {
                el.classList.add(`d-${env}-none`);

                if (window.getComputedStyle(el).display === 'none') {
                    curEnv = env;
                    break;
                }
            }

            document.body.removeChild(el);
            return curEnv;
        }

        function TextClic() {

        }
    </script>

