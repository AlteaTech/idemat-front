                                                <div class="row mb-3">
                                                    <div class="col-xl-6">
                                                        <label for="immatriculation" class="form-label idematlabelsaisienoir">Immatriculation du véhicule</label>
                                                        <input asp-for="Usager.ImmatEnCours" type="text" class="form-control idematsaisiefondblanc" id="immatriculationpro" placeholder="Ex : AB123CD" value="@(Model.Usager == null ? "" : Model.Usager.ImmatEnCours)">
