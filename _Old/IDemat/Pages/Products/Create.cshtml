                                                        {
                                                            <div style="color:red">@Html.Raw("L'immatriculation est obligatoire")</div>
                                                        }
                                                    </div>
                                                    <div class="col-xl-6">
                                                        <label for="UploadCG" class="form-label idematlabelsaisienoir">Carte grise</label>
                                                        <input type="file" asp-for="UploadCG" accept=".pdf, .jpg, .jpeg, .gif, .png" class="form-control" id="carteGrisepro" title="Carte grise" lang="fr" style="border: none;">
                                                        @if (Model.Variables.erreurCG)
                                                        {
                                                            <div style="color:red">@Html.Raw("Vous devez joindre votre carte grise")</div>
                                                        }

                                                    </div>
                                                </div>
                                                @if (Model.Variables.blnDemandeZoneJ1F3)
                                                {
                                                    <div class="row mb-3">
                                                        <div class="col-xl-6">
                                                            <label for="zoneJ1CG" class="form-label idematlabelsaisienoir">Zone J.1 de la carte grise</label>
                                                            <select asp-for="Usager.ImmatJ1EnCours" asp-items="Model.ZoneJ1CG" class="form-control idematsaisiefondblanc" id="immatriculationJ1pro"><option value="">-- Sélectionnez le genre national --</option> <!-- Empty option --></select>
                                                        </div>
                                                        <div class="col-xl-6">
                                                            <label for="UploadCG" class="form-label idematlabelsaisienoir">Zone F.3 de la carte grise</label>
                                                            <input asp-for="Usager.ImmatF3EnCours" type="text" class="form-control idematsaisiefondblanc" id="immatriculationF3pro" value="@(Model.Usager == null ? "" : Model.Usager.ImmatF3EnCours)">
                                                            @if (Model.Variables.erreurF3)
                                                            {
                                                                <div style="color:red">@Html.Raw("Le poids doit être un nombre entier")</div>
                                                            }
                                                        </div>
                                                    </div>
                                                }
                                                <input id="btnAjouterImmat" type="submit" value="Ajouter le véhicule" class="btn btn-primary idematbtnblancfondtransparent" asp-page-handler="AjoutImmatPro" asp-route-idEnseigne="@Model.Variables.idEnseigne" asp-route-strImmatriculations="@Model.Variables.strImmatriculations" asp-route-guidCreation="@Model.Variables.guidCreation.ToString()" />

                                                @{
                                                    int index = 1;
                                                    foreach (string immat in Model.Variables.strImmatriculations.Split(";").ToList())
                                                    {
                                                        <div class="idematlabelentetenoirgras">
                                                            @immat
                                                        </div>
                                                        index++;
                                                    }
                                                }
                                            </div>
                                        }

                                        <!-- Kbis -->
                                        <div class="idematcard">
                                            <img src="~/Images/Carte de membre.svg" alt="Carte de membre Image" style="margin-right: 10px; vertical-align: text-bottom;" /><label for="" class="form-label idematlabelentetebloc">Kbis</label><br />
                                            <div class="row mb-3">
                                                <div class="col-xl-12">
                                                    <input type="file" asp-for="UploadKB" accept=".pdf, .jpg, .jpeg, .gif, .png" class="form-control" id="kbis" title="KBis" lang="fr" style="border: none;">
                                                    @if (Model.Variables.erreurKB)
                                                    {
                                                        <div style="color:red">@Html.Raw("Vous devez joindre votre Kbis")</div>
                                                    }
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Conditions générales -->
                                        <div class="idematcard">
                                            <img src="~/Images/Fiche.svg" alt="Fiche Image" style="margin-right: 10px; vertical-align: text-bottom;" /><label for="" class="form-label idematlabelentetebloc">
                                                Conditions générales
                                            </label><br />
                                            <p class="idematlabelaffichagenoir">
                                                <div class="idematlabelmultilinenoir" style="height: 150px;overflow-y: scroll">@Html.Raw(@Model.Variables.strMentionsLegales)</div><br />
                                            </p>
                                            <div class="form-check">
                                                <input asp-for="blnMentionsLegales" id="chkMentionsLegalespro" class="form-check-input" type="checkbox">
                                                <label class="form-check-label" for="acceptConditions">
                                                    J'ai lu et accepté les conditions générales
                                                </label>
                                                @if (Model.Variables.erreurMentionsLegales)
                                                {
                                                    <div style="color:red">@Html.Raw("Vous devez accepter les conditions générales")</div>
                                                }

                                            </div>
                                        </div>

                                        <!-- Bouton de validation -->
                                        <div class="text-center">
                                            <button type="submit" class="idematbtnrouge" asp-page-handler="EnregistrerPro"><img src="~/Images/Check.svg" alt="Check Image" style="margin-right: 10px; margin-top: 5px; vertical-align: text-bottom;" />Envoyer ma demande d'inscription</button>
                                        </div>
                                    </form>
                                </div>


                            </div>
                            <div class="col-md-2 col-sm-1 d-none d-sm-block"></div>
                        </div>
                    </div>
            </main>
        </div>
    </div>

</div>


