                                                    {
                                                        <div style="color:red">@Html.Raw("L'e-mail est obligatoire")</div>
                                                    }
                                                    @if (Model.Variables.erreurEmail != "")
                                                    {
                                                        <div style="color:red">@Model.Variables.erreurEmail</div>
                                                    }
                                                    @if (Model.Variables.erreurUniciteEmail)
                                                    {
                                                        <div style="color:red">@Html.Raw("Un compte existe déjà avec cette adresse email")</div>
                                                    }
                                                </div>
                                                <div class="col-xl-6">
                                                    <label for="telephone" class="form-label idematlabelsaisienoir">Téléphone</label>
                                                    <input type="tel" class="form-control idematsaisiefondblanc" id="Telephonepro" asp-for="Usager.Telephone">
                                                    <span asp-validation-for="Usager.Telephone" class="text-danger"></span>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Carte d'accès -->
                                        @if (Model.Variables.blnCarteDemat && Model.Variables.blnCartePhysique)
                                        {
                                            <div class="idematcard">
                                                <img src="~/Images/Carte a puce.svg" alt="Carte a puce Image" style="margin-right: 10px; vertical-align: text-bottom;" /><label for="" class="form-label idematlabelentetebloc">Carte d'accès</label><br />
                                                <div class="col mb-3">
                                                    @foreach (var typecarte in Model.Listes.TypesCarte)
                                                    {
                                                        <input type="radio" asp-for="Usager.TypeCarte" value="@typecarte" />@Html.Raw("&nbsp;")@typecarte<br />
                                                    }

                                                    <span asp-validation-for="Usager.TypeCarte" class="text-danger"></span>
