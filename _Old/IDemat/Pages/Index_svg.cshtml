@page "{contrat}"
@model IndexModel

@{
    ViewData["Title"] = "Bienvenue";
    ViewData["Logo"] = Model.Variables.strURLLogo;
}

<div class="container-fluid idematbackgroundlogin">
    <img src=@ViewData["Logo"].ToString() alt="Logo" class="idematlogoPC">
    <div class="idematlogoTPcontainer">
        <img src=@ViewData["Logo"].ToString() alt="Logo" class="idematlogoTP">
    </div>
    <div class="idematcontainercentre">
        <form method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Identifiant.IdEnseigne" value="@Model.Variables.idEnseigne" />
            <div class="form-group">
                <p class="idematlabelsaisieblanc">Identifiant</p>
                <input asp-for="Identifiant.Login" class="form-control idematsaisiefondtransparent80pc" />
                <span asp-validation-for="Identifiant.Login" class="text-danger"></span>
            </div>
            <div class="form-group">
                @*<label asp-for="Usager.Prenom" class="control-label"></label>*@
                <p class="idematlabelsaisieblanc">Mot de passe</p>
                <input asp-for="Identifiant.Motdepasse" class="form-control idematsaisiefondtransparent80pc" />
                <span asp-validation-for="Identifiant.Motdepasse" class="text-danger"></span>
            </div>
            <p class="text-center"><a href="MotDePasseOublie/@Model.contrat" class="idematlabelsaisieblanc">J&rsquo;ai oublié mon mot de passe</a></p>
            <div class="form-group">
                <input type="submit" value="Se connecter" class="btn idematbtnrougefondblanc" asp-page-handler="Identifier" />
            </div>
            @if (Model.Variables.erreurLogin)
            {
                <div class="idematlabelsaisieblanc"><br />@Html.Raw("Votre identifiant est incorrect")<br /><br /></div>
            }
            @if (Model.Variables.erreurMotdepasse)
            {
                <div class="idematlabelsaisieblanc"><br />@Html.Raw("Votre mot de passe est incorrect")<br /><br /></div>
            }
            @if (Model.Variables.erreurCompteSupprime)
            {
                <div class="idematlabelsaisieblanc"><br />@Html.Raw("Ce compte a été supprimé à votre demande")<br /><br /></div>
            }
            <br />
            <hr class="idematligneseparatrice">
            <br />
            <p class="text-center idematlabelsaisieblanc">Vous n&rsquo;avez pas encore de compte ?<br /><b><a href="Products/Create/@Model.contrat" class="btn idematbtnblancfondtransparent">S&rsquo;inscrire</a></b></p>
        </form>
    </div>
</div>





